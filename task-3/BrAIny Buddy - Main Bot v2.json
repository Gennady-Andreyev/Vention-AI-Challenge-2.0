    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst aiItem = items[0].json;\n\nlet rawOutput = aiItem.output || aiItem.text || aiItem.response || aiItem.result || aiItem.content || '';\n\nif (typeof rawOutput === 'object') {\n  rawOutput = JSON.stringify(rawOutput);\n}\n\n// Strip markdown code fences\nrawOutput = rawOutput.replace(/^```json\\s*/i, '').replace(/```\\s*$/, '');\n\n// Find first JSON object\nconst jsonMatch = rawOutput.match(/\\{[\\s\\S]*\\}/);\nif (!jsonMatch) {\n  throw new Error('No JSON object found in AI output');\n}\n\nlet parsed;\ntry {\n  parsed = JSON.parse(jsonMatch[0]);\n} catch (e) {\n  throw new Error('Failed to parse JSON: ' + e.message);\n}\n\n// Validate and normalize\nconst title = parsed.title || 'Untitled';\nconst summary = parsed.summary || 'No summary available';\nconst keyPoints = Array.isArray(parsed.keyPoints) ? parsed.keyPoints : [];\nconst concepts = Array.isArray(parsed.concepts) ? parsed.concepts : [];\nlet difficulty = parsed.difficulty || 'intermediate';\n\nif (!['beginner', 'intermediate', 'advanced'].includes(difficulty)) {\n  difficulty = 'intermediate';\n}\n\nreturn [{\n  json: {\n    title,\n    summary,\n    keyPoints,\n    concepts,\n    difficulty\n  }\n}];"
      },
      "id": "887c3865-c67f-49bf-aef6-3e4d4abf55b9",
      "name": "Parse Teacher JSON",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1936,
        592
      ]
    },
    {
      "parameters": {
        "jsCode": "const input = $input.first();\n\nif (!input || !input.json) {\n  throw new Error('Prepare Material Data received no input item');\n}\n\nconst teacher = input.json;\n\nconst cleaned = $('Clean HTML Content').first().json;\n\nconst now = new Date().toISOString();\nconst materialId = `LM-${Date.now()}`;\n\nconst keyPoints = Array.isArray(teacher.keyPoints) ? teacher.keyPoints : [];\nconst concepts = Array.isArray(teacher.concepts) ? teacher.concepts : [];\n\nreturn [\n  {\n    json: {\n      materialId,\n      userId: cleaned.userId,\n      chatId: cleaned.chatId,\n      url: cleaned.url,\n      title: teacher.title || cleaned.title || cleaned.url,\n      content: cleaned.content,\n      summary: teacher.summary,\n      keyPointsJson: JSON.stringify(keyPoints),\n      conceptsJson: JSON.stringify(concepts),\n      difficulty: teacher.difficulty || 'intermediate',\n      addedAt: now,\n    },\n  },\n];\n"
      },
