      "parameters": {
        "jsCode": "const items = $input.all();\nconst normalized = [];\n\nfor (const item of items) {\n  const data = item.json;\n  \n  let eventType = 'unknown';\n  let chatId = null;\n  let userId = null;\n  let text = '';\n  let callbackData = '';\n  let callbackQueryId = '';\n  let firstName = '';\n  \n  if (data.message) {\n    eventType = 'message';\n    chatId = data.message.chat?.id || null;\n    userId = data.message.from?.id || null;\n    text = data.message.text || '';\n    firstName = data.message.from?.first_name || '';\n  } else if (data.callback_query) {\n    eventType = 'callback_query';\n    chatId = data.callback_query.message?.chat?.id || null;\n    userId = data.callback_query.from?.id || null;\n    callbackData = data.callback_query.data || '';\n    callbackQueryId = data.callback_query.id || '';\n    firstName = data.callback_query.from?.first_name || '';\n  }\n  \n  normalized.push({\n    json: {\n      eventType,\n      chatId,\n      userId,\n      text,\n      callbackData,\n      callbackQueryId,\n      firstName\n    }\n  });\n}\n\nreturn normalized;"
      },
